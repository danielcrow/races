# Single-Tenant Race Timing Platform - Local Development Environment
# Each deployment serves one organization with its own isolated database
# To run multiple organizations, deploy separate instances (see VERCEL_MULTI_TENANT_GUIDE.md)

# Auth.js Configuration
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-here

# Vercel Blob Storage
# Get your token from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Application URL
NEXTAUTH_URL=http://localhost:3000

# Upstash Redis (Vercel KV) for persistent storage
# Get these from Vercel Dashboard > Storage > Create KV Database
# Or from Upstash Console: https://console.upstash.com/
KV_REST_API_URL=your-kv-rest-api-url
KV_REST_API_TOKEN=your-kv-rest-api-token

# PostgreSQL Database
# For local development: postgresql://user:password@localhost:5432/race_timing
# For Vercel: Get from Vercel Dashboard > Storage > Create Postgres Database
# Or use any PostgreSQL provider (Supabase, Railway, Neon, etc.)
POSTGRES_URL=postgresql://user:password@localhost:5432/race_timing
# Alternative variable name (some providers use this)
# DATABASE_URL=postgresql://user:password@localhost:5432/race_timing